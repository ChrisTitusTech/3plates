{
  "name": "3plates",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "esbuild": "0.27.7",
      "postcss": "8.5.10"
    }
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @3plates/api --filter @3plates/mobile dev",
    "dev:api": "pnpm --filter @3plates/api dev",
    "dev:mobile": "pnpm --filter @3plates/mobile dev",
    "db:up": "docker-compose up -d postgres",
    "db:down": "docker-compose down",
    "db:wait": "bash ./scripts/db-wait.sh",
    "db:generate": "pnpm --filter @3plates/db generate",
    "db:migrate": "pnpm --filter @3plates/db migrate",
    "db:setup": "pnpm db:up && pnpm db:wait && pnpm db:migrate",
    "db:reset": "docker-compose down -v && docker-compose up -d postgres && pnpm db:wait && pnpm db:migrate",
    "db:logs": "docker-compose logs -f postgres",
    "db:test": "bash ./scripts/db-smoke-test.sh",
    "typecheck": "pnpm --filter @3plates/contract typecheck && pnpm --filter @3plates/db typecheck && pnpm --filter @3plates/api typecheck && pnpm --filter @3plates/mobile typecheck",
    "test": "pnpm --filter @3plates/contract test && pnpm --filter @3plates/api test"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
